<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PracticaGymTracker.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="PracticaGymTracker.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="PracticaGymTracker">
    
    <Grid ColumnDefinitions="200, *">
        <Border Grid.Column="0" Background="#1E1E1E" Padding="15,20,15,20">
            <StackPanel Spacing="15">
                
                <TextBlock Text="GYM TRACKER" 
                           Foreground="#FF6347" 
                           FontSize="22" 
                           FontWeight="Black" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,30"
                           LetterSpacing="2"/> <Button Content="Головна" 
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Background="Transparent" Foreground="#FFFFFF" 
                        FontSize="16" FontWeight="SemiBold" Padding="15,10"/>
                        
                <Button Content="Тренування" 
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Background="#FF6347" Foreground="#FFFFFF" 
                        FontSize="16" FontWeight="SemiBold" Padding="15,10" CornerRadius="8"/>
                        
                <Button Content="Налаштування" 
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Background="Transparent" Foreground="#FFFFFF" 
                        FontSize="16" FontWeight="SemiBold" Padding="15,10"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Padding="30">
            <StackPanel>
                
                <TextBlock Text="ДЕНЬ СПИНИ ТА БІЦЕПСА" 
                           Foreground="#FFFFFF" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Margin="0,0,0,5"/>
                           
                <TextBlock Text="Сьогодні чудовий день, щоб побити свої рекорди." 
                           Foreground="#888888" 
                           FontSize="14" 
                           Margin="0,0,0,30"/>
                           
                <Border Background="#1E1E1E" CornerRadius="12" Padding="20" Height="200">
                    <TextBlock Text="Місце для графіка 1RM або карток тренувань" 
                               Foreground="#888888" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                </Border>
                
            </StackPanel>
        </Border>

    </Grid>


</Window>
