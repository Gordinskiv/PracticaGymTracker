<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PracticaGymTracker.ViewModels"
             x:DataType="vm:HomeViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="PracticaGymTracker.Views.Pages.HomeView">

    <ScrollViewer Padding="30">
        <StackPanel Spacing="20">
            <TextBlock Text="{DynamicResource HomeTitle}" FontSize="28" FontWeight="Black" Foreground="White" />

            <UniformGrid Columns="3">
                <Border Classes="StatCard">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource HomeStat1}" Classes="StatLabel" />
                        <TextBlock Text="{Binding WorkoutsThisWeek}" Classes="StatValue" />
                    </StackPanel>
                </Border>

                <Border Classes="StatCard">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource HomeStat2}" Classes="StatLabel" />
                        <TextBlock Text="{Binding MaxRecord}" Classes="StatValue" />
                    </StackPanel>
                </Border>

                <Border Classes="StatCard">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource HomeStat3}" Classes="StatLabel" />
                        <TextBlock Text="{Binding FavoriteExercise}" Classes="StatValue" FontSize="18" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock Text="{DynamicResource HomeRecent}" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,20,0,10" />
            <Border Background="{DynamicResource BgBeige}" CornerRadius="12" Height="200">
                <ItemsControl ItemsSource="{Binding RecentLogs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,20">
                                <Border Grid.Column="0" 
                                        Background="#22FF4500" 
                                        CornerRadius="8" 
                                        Width="45" Height="45" 
                                        Margin="0,0,15,0">
                                    <PathIcon Data="M22 12h-4l-3 9L9 3l-3 9H2" 
                                              Width="20" Height="20" 
                                              Foreground="{DynamicResource AccentMain}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TextWhite}"/>
                                    <TextBlock Text="{Binding Summary}" FontSize="13" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" 
                                           Text="{Binding Date}" 
                                           FontWeight="Black" 
                                           Foreground="{DynamicResource AccentMain}" 
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>