<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PracticaGymTracker.ViewModels"
             x:DataType="vm:ExercisesCatalogViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="PracticaGymTracker.Views.Pages.ExercisesCatalogView">

    <Grid ColumnDefinitions="3*, 2*">

        <ScrollViewer Grid.Column="0" Padding="0,0,20,0">
            <StackPanel Spacing="20">
                <TextBlock Text="{DynamicResource ExercisesCatalog}" FontSize="28" FontWeight="Black"
                           Foreground="{DynamicResource TextWhite}" />

                <ItemsControl ItemsSource="{Binding Catalog}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="{Binding GroupName}" Foreground="{DynamicResource AccentMain}"
                                           FontWeight="Black" FontSize="16" Margin="0,0,0,10" />

                                <ItemsControl ItemsSource="{Binding Exercises}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Name}"
                                                    Background="{DynamicResource BgCard}"
                                                    Foreground="{DynamicResource TextWhite}"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left"
                                                    Margin="0,0,0,5" Padding="15,10"
                                                    CornerRadius="8" Cursor="Hand" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="1" Background="{DynamicResource BgCard}" CornerRadius="16" Padding="20">
            <Grid RowDefinitions="Auto, *">

                <TextBlock Grid.Row="0" Text="{Binding SelectedExerciseName}"
                           TextWrapping="Wrap" TextAlignment="Center"
                           FontWeight="Bold" FontSize="20" Foreground="{DynamicResource TextWhite}" />

                <Viewbox Grid.Row="1" Margin="20">
                    <Canvas Width="100" Height="250">
                        <Ellipse Canvas.Left="35" Canvas.Top="10" Width="30" Height="30" Fill="#333333" />
                        <Path Data="M 20,50 L 80,50 L 65,120 L 35,120 Z" Fill="#333333" />
                        <Path Data="M 35,125 L 48,125 L 48,240 L 35,240 Z" Fill="#333333" />
                        <Path Data="M 52,125 L 65,125 L 65,240 L 52,240 Z" Fill="#333333" />
                        <Path Data="M 10,55 L 20,55 L 15,140 L 5,140 Z" Fill="#333333" />
                        <Path Data="M 80,55 L 90,55 L 95,140 L 85,140 Z" Fill="#333333" />
                        
                    </Canvas>
                </Viewbox>
            </Grid>
        </Border>

    </Grid>

</UserControl>