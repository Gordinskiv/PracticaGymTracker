<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PracticaGymTracker.ViewModels"
             x:DataType="vm:LoginViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="PracticaGymTracker.Views.Pages.LoginView">

    <Panel Background="{DynamicResource BgDark}">

        <Border Background="{DynamicResource BgCard}"
                CornerRadius="16"
                Padding="40"
                Width="400"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BoxShadow="0 10 30 0 #44000000">
            <StackPanel Spacing="20">
                <TextBlock Text="GYM TRACKER"
                           FontSize="32"
                           FontWeight="Black"
                           Foreground="{DynamicResource AccentMain}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10" />

                <TextBlock Text="Увійдіть, щоб продовжити"
                           Foreground="{DynamicResource TextMuted}"
                           HorizontalAlignment="Center"
                           Margin="0,-10,0,20" />

                <TextBox Watermark="Логін або Email"
                         FontSize="16"
                         Padding="15" />

                <TextBox Watermark="Пароль"
                         PasswordChar="•"
                         FontSize="16"
                         Padding="15" />

                <TextBlock Text="Забули пароль?"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="12"
                           HorizontalAlignment="Right"
                           Cursor="Hand"
                           Margin="0,-10,0,10" />

                <Button Content="УВІЙТИ"
                        Command="{Binding LoginCommand}"
                        Background="{DynamicResource AccentMain}"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="18"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Padding="15"
                        CornerRadius="8"
                        Cursor="Hand" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <TextBlock Text="Немає акаунту? " Foreground="{DynamicResource TextMuted}" />
                    <TextBlock Text="Створити зараз" Foreground="{DynamicResource AccentMain}" FontWeight="Bold"
                               Cursor="Hand" />
                </StackPanel>
            </StackPanel>   
        </Border>
    </Panel>

</UserControl>