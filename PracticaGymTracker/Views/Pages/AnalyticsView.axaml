<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PracticaGymTracker.ViewModels"
             x:DataType="vm:AnalyticsViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="PracticaGymTracker.Views.Pages.AnalyticsView">
    
    <ScrollViewer Padding="20">
        <StackPanel Spacing="25">
            <TextBlock Text="АНАЛІТИКА ТА ЗАМІРИ" FontSize="28" FontWeight="Black" Foreground="{DynamicResource TextWhite}"/>

            <Border Background="{DynamicResource BgCard}" CornerRadius="12" Padding="20" Height="200">
                <Grid>
                    <TextBlock Text="ПРОГРЕС ВАГИ (КГ)" FontSize="14" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Top"/>
                    <Polyline Points="0,150 50,140 100,145 150,120 200,130 250,100 300,110 350,80 400,90 450,70 500,80 550,50 600,60 650,30" 
                              Stroke="{DynamicResource AccentMain}" StrokeThickness="3" 
                              VerticalAlignment="Bottom" Margin="0,0,0,20"/>
                </Grid>
            </Border>

            <TextBlock Text="ІСТОРІЯ ЗАМІРІВ" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextWhite}"/>
            <Border Background="{DynamicResource BgCard}" CornerRadius="12" Padding="15">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*, *, *, *, *" Margin="0,0,0,10">
                        <TextBlock Grid.Column="0" Text="ДАТА" FontWeight="Black" Foreground="{DynamicResource TextMuted}"/>
                        <TextBlock Grid.Column="1" Text="ВАГА" FontWeight="Black" Foreground="{DynamicResource TextMuted}"/>
                        <TextBlock Grid.Column="2" Text="ГРУДИ" FontWeight="Black" Foreground="{DynamicResource TextMuted}"/>
                        <TextBlock Grid.Column="3" Text="БІЦЕПС" FontWeight="Black" Foreground="{DynamicResource TextMuted}"/>
                        <TextBlock Grid.Column="4" Text="ТАЛІЯ" FontWeight="Black" Foreground="{DynamicResource TextMuted}"/>
                    </Grid>
                    
                    <Grid ColumnDefinitions="*, *, *, *, *">
                        <TextBlock Grid.Column="0" Text="14.04.26" Foreground="{DynamicResource TextWhite}"/>
                        <TextBlock Grid.Column="1" Text="62.5 кг" Foreground="{DynamicResource AccentMain}"/>
                        <TextBlock Grid.Column="2" Text="95 см" Foreground="{DynamicResource TextWhite}"/>
                        <TextBlock Grid.Column="3" Text="34 см" Foreground="{DynamicResource TextWhite}"/>
                        <TextBlock Grid.Column="4" Text="78 см" Foreground="{DynamicResource TextWhite}"/>
                    </Grid>
                    <Separator Background="#33FFFFFF"/>
                    <Grid ColumnDefinitions="*, *, *, *, *">
                        <TextBlock Grid.Column="0" Text="01.04.26" Foreground="{DynamicResource TextWhite}"/>
                        <TextBlock Grid.Column="1" Text="61.0 кг" Foreground="{DynamicResource AccentMain}"/>
                        <TextBlock Grid.Column="2" Text="94 см" Foreground="{DynamicResource TextWhite}"/>
                        <TextBlock Grid.Column="3" Text="33.5 см" Foreground="{DynamicResource TextWhite}"/>
                        <TextBlock Grid.Column="4" Text="79 см" Foreground="{DynamicResource TextWhite}"/>
                    </Grid>
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource BgCard}" CornerRadius="12" Padding="20">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBlock Text="МЕТА: 75 КГ" FontWeight="Black" FontSize="16" Foreground="{DynamicResource TextWhite}"/>
                        <TextBlock Grid.Column="1" Text="82%" FontWeight="Bold" Foreground="{DynamicResource AccentMain}"/>
                    </Grid>
        
                    <ProgressBar Value="82" Height="10" CornerRadius="5"
                                 Background="#33FFFFFF"
                                 Foreground="{DynamicResource AccentMain}"/>
        
                    <TextBlock Text="Залишилося набрати: 12.5 кг" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
